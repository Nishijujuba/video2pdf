{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/acceptance-criteria.v1.json",
  "title": "Final Delivery Acceptance Criteria",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "criteria_version",
    "name",
    "scope",
    "review_context_policy",
    "evaluation_policy",
    "criteria"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "criteria_version": { "const": "1.0" },
    "name": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["final_artifacts", "excluded_artifacts"],
      "properties": {
        "final_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "excluded_artifacts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "review_context_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["final_artifacts_and_criteria_only", "forbid_generation_process"],
      "properties": {
        "final_artifacts_and_criteria_only": { "const": true },
        "forbid_generation_process": { "const": true }
      }
    },
    "evaluation_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocking_only", "fail_fast", "report_all_failures", "allowed_categories"],
      "properties": {
        "blocking_only": { "const": true },
        "fail_fast": { "const": false },
        "report_all_failures": { "const": true },
        "allowed_categories": {
          "type": "array",
          "items": {
            "enum": [
              "style",
              "logic_readability",
              "formula_information_gain",
              "figure_visual_integrity",
              "table_layout_integrity",
              "credibility_disclosure_placement"
            ]
          }
        }
      }
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "category",
          "rule",
          "violation_patterns",
          "allowed_exceptions",
          "scan_policy",
          "pass_condition",
          "fail_condition"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "category": {
            "enum": [
              "style",
              "logic_readability",
              "formula_information_gain",
              "figure_visual_integrity",
              "table_layout_integrity",
              "credibility_disclosure_placement"
            ]
          },
          "rule": { "type": "string", "minLength": 1 },
          "violation_patterns": {
            "type": "array",
            "items": { "type": "string" }
          },
          "allowed_exceptions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "scan_policy": {
            "enum": [
              "full_artifact_style_scan",
              "triggered_structural_expression_scan",
              "full_artifact_formula_scan",
              "full_rendered_pdf_visual_scan"
            ]
          },
          "pass_condition": { "type": "string", "minLength": 1 },
          "fail_condition": { "type": "string", "minLength": 1 },
          "trigger_condition": { "type": "string", "minLength": 1 },
          "excluded_contexts": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "examples": {
            "type": "object",
            "additionalProperties": false,
            "required": ["fail", "pass"],
            "properties": {
              "fail": { "$ref": "#/$defs/example" },
              "pass": { "$ref": "#/$defs/example" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "example": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "reason"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
