{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/exit-evidence-manifest.v2.schema.json",
  "title": "Video Workflow Exit Evidence Manifest v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "kind",
    "fingerprint_algorithm",
    "slice",
    "slice_base_commit",
    "implementation_commit",
    "evidence_paths",
    "generated_at",
    "activation_scope",
    "commands",
    "expected_checkpoints",
    "fixtures",
    "results",
    "artifact_fingerprints",
    "unresolved_exceptions",
    "overall_decision"
  ],
  "properties": {
    "$schema": {"const": "https://video2pdf.local/schemas/exit-evidence-manifest.v2.schema.json"},
    "schema_version": {"const": 2},
    "kind": {"const": "video-workflow-exit-evidence"},
    "fingerprint_algorithm": {"const": "sha256-raw-v1"},
    "slice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "name"],
      "properties": {
        "number": {"enum": [1, 2, 3, 4, 5, 6]},
        "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,79}$"}
      }
    },
    "slice_base_commit": {"$ref": "#/$defs/gitCommit"},
    "implementation_commit": {"$ref": "#/$defs/gitCommit"},
    "evidence_paths": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/projectPath"}
    },
    "generated_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "activation_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "runtime_authority_change", "components_activated", "legacy_track_authority"],
      "properties": {
        "kind": {"const": "none"},
        "runtime_authority_change": {"const": false},
        "components_activated": {"type": "array", "maxItems": 0},
        "legacy_track_authority": {"const": "preserved"}
      }
    },
    "commands": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "#/$defs/commandEvidence"}
    },
    "expected_checkpoints": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "status": {"enum": ["current", "stale", "blocked"]}
        }
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/fingerprintedArtifact"}
    },
    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": ["positive", "negative", "recovery"],
      "properties": {
        "positive": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "negative": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "quota": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "fencing": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "fairness": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "restart": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "recovery": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "result_bindings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/resultBinding"}
    },
    "fault_points": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_]{2,119}$"}
    },
    "platform_smokes": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/platformSmokeEvidence"},
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": ["platform"],
            "properties": {"platform": {"const": "bilibili"}}
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "required": ["platform"],
            "properties": {"platform": {"const": "youtube"}}
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    },
    "artifact_fingerprints": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/fingerprintedArtifact"}
    },
    "unresolved_exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["blocking", "code", "message"],
        "properties": {
          "blocking": {"type": "boolean"},
          "code": {"type": "string", "minLength": 1},
          "message": {"type": "string", "minLength": 1}
        }
      }
    },
    "overall_decision": {"enum": ["pass", "fail"]}
  },
  "oneOf": [
    {
      "properties": {
        "slice": {
          "properties": {
            "number": {"const": 1},
            "name": {"const": "offline-source-ready-tracer"}
          }
        },
        "slice_base_commit": {"const": "96089b99c9ae63fff61107e1920fc3481ffc0802"},
        "result_bindings": false,
        "fault_points": false,
        "platform_smokes": false
      }
    },
    {
      "properties": {
        "slice": {
          "properties": {
            "number": {"const": 2},
            "name": {"const": "fenced-task-execution-and-promotion"}
          }
        },
        "slice_base_commit": {"const": "904f46409b87aca96aeecf5cb0be4855c2cfdafa"},
        "results": {"required": ["fencing"]},
        "result_bindings": false,
        "fault_points": false,
        "platform_smokes": false
      }
    },
    {
      "required": ["result_bindings", "fault_points"],
      "properties": {
        "slice": {
          "properties": {
            "number": {"const": 3},
            "name": {"const": "cross-run-resource-admission"}
          }
        },
        "slice_base_commit": {"const": "aaaaeac5747fddc0915a59df34de47e6e8cfec48"},
        "results": {"required": ["quota", "fencing", "fairness", "restart", "recovery"]},
        "platform_smokes": false
      }
    },
    {
      "required": ["result_bindings", "fault_points", "platform_smokes"],
      "properties": {
        "slice": {
          "properties": {
            "number": {"const": 4},
            "name": {"const": "production-source-acquisition"}
          }
        },
        "slice_base_commit": {"const": "654362017fa974946fb252af5311868bb47efcf0"},
        "results": {"required": ["fencing", "restart", "recovery"]}
      }
    },
    {
      "required": ["result_bindings"],
      "properties": {
        "slice": {
          "properties": {
            "number": {"const": 5},
            "name": {"const": "single-section-production"}
          }
        },
        "slice_base_commit": {"const": "7b33a2dcf8b19608943f12efd814907a69c35e8f"},
        "fault_points": false,
        "platform_smokes": false
      }
    },
    {
      "required": ["result_bindings"],
      "properties": {
        "slice": {"properties": {"number": {"const": 6}, "name": {"const": "multi-section-production"}}},
        "slice_base_commit": {"const": "6f8241ddb4bd725d3b584dd1c403ed59dda32219"},
        "results": {
          "required": ["fencing", "restart", "recovery"],
          "properties": {"positive": {"contains": {"const": "deterministic_integration"}}}
        },
        "fault_points": false,
        "platform_smokes": false
      }
    }
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "gitCommit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "projectPath": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"},
    "fingerprintedArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "path", "sha256"],
      "properties": {
        "role": {"type": "string", "minLength": 1},
        "path": {"$ref": "#/$defs/projectPath"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "commandEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["test_id", "command", "expected_exit_code", "actual_exit_code", "log", "conforms"],
      "properties": {
        "test_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,79}$"},
        "command": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "expected_exit_code": {"type": "integer", "minimum": 0, "maximum": 255},
        "actual_exit_code": {"type": "integer", "minimum": 0, "maximum": 255},
        "log": {"$ref": "#/$defs/fingerprintedArtifact"},
        "conforms": {"type": "boolean"}
      }
    },
    "resultBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_id", "result_kind", "command_id", "test_target"],
      "properties": {
        "result_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,119}$"},
        "result_kind": {"enum": ["positive", "negative", "quota", "fencing", "fairness", "restart", "recovery"]},
        "command_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,79}$"},
        "test_target": {"type": "string", "pattern": "^tests\\.video_workflow\\.[A-Za-z0-9_.]+$"}
      }
    },
    "platformSmokeEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "adapter_id",
        "adapter_contract_version",
        "provider_kind",
        "run_id",
        "command_id",
        "command_argv_redacted",
        "authentication_classification",
        "tool_versions",
        "target_checkpoint",
        "source_manifest",
        "sanitized_log",
        "runtime_policy_sha256",
        "recorded_at"
      ],
      "properties": {
        "platform": {"enum": ["bilibili", "youtube"]},
        "adapter_id": {"enum": ["bilibili", "youtube"]},
        "adapter_contract_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "provider_kind": {"const": "live"},
        "run_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
        "command_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,79}$"},
        "command_argv_redacted": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "authentication_classification": {
          "enum": [
            "not_applicable",
            "anonymous",
            "cookie_accepted",
            "cookie_missing",
            "cookie_unreadable",
            "cookie_rejected",
            "cookie_expired"
          ]
        },
        "tool_versions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"type": "string", "minLength": 1}
        },
        "target_checkpoint": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "status", "evidence_sha256"],
          "properties": {
            "name": {"const": "source_ready"},
            "status": {"const": "current"},
            "evidence_sha256": {"$ref": "#/$defs/sha256"}
          }
        },
        "source_manifest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256", "canonical_platform", "canonical_item_id", "source_identity", "source_version"],
          "properties": {
            "path": {"$ref": "#/$defs/projectPath"},
            "sha256": {"$ref": "#/$defs/sha256"},
            "canonical_platform": {"enum": ["bilibili", "youtube"]},
            "canonical_item_id": {"type": "string", "minLength": 1, "maxLength": 256},
            "source_identity": {"$ref": "#/$defs/sha256"},
            "source_version": {"$ref": "#/$defs/sha256"}
          }
        },
        "sanitized_log": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256", "no_secret_scan"],
          "properties": {
            "path": {"$ref": "#/$defs/projectPath"},
            "sha256": {"$ref": "#/$defs/sha256"},
            "no_secret_scan": {"const": "pass"}
          }
        },
        "runtime_policy_sha256": {"$ref": "#/$defs/sha256"},
        "recorded_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}
