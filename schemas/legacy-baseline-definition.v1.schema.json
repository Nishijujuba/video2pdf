{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/legacy-baseline-definition.v1.schema.json",
  "title": "Legacy Workflow Baseline Definition v1",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "kind",
    "normalization_version",
    "baselines",
    "slice_verifications",
    "authority_guards"
  ],
  "properties": {
    "$schema": {
      "const": "https://video2pdf.local/schemas/legacy-baseline-definition.v1.schema.json"
    },
    "schema_version": { "const": 1 },
    "kind": { "const": "legacy-workflow-baseline-definition" },
    "normalization_version": { "const": 1 },
    "baselines": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/command" }
    },
    "slice_verifications": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/command" }
    },
    "authority_guards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "required_substrings"],
        "properties": {
          "path": { "$ref": "#/$defs/projectPath" },
          "required_substrings": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "command": {
      "type": "object",
      "required": [
        "test_id",
        "category",
        "command",
        "timeout_seconds",
        "expected_status",
        "expected_log_sha256"
      ],
      "properties": {
        "test_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,79}$"
        },
        "category": {
          "enum": [
            "pyramid",
            "compile",
            "acceptance",
            "delivery_guard",
            "batch",
            "slice_verification"
          ]
        },
        "command": {
          "type": "array",
          "minItems": 2,
          "prefixItems": [{ "const": "{python}" }],
          "items": { "type": "string", "minLength": 1 }
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "expected_status": {
          "enum": ["pass", "fail"]
        },
        "expected_log_sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    }
  }
}
