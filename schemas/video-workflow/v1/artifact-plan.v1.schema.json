{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v1/artifact-plan.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "kernel_version", "run_id", "artifacts"],
  "properties": {
    "schema_name": {"const": "artifact-plan"},
    "schema_version": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/schema_version"},
    "kernel_version": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/kernel_version"},
    "run_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/run_id"},
    "artifacts": {
      "type": "array", "minItems": 3, "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["logical_id", "path", "schema_name", "generator", "earliest_checkpoint"],
        "properties": {
          "logical_id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "schema_name": {"type": "string", "minLength": 1},
          "generator": {"type": "string", "pattern": "^kernel:"},
          "earliest_checkpoint": {"enum": ["run_initialized", "source_ready"]}
        }
      }
    }
  }
}
