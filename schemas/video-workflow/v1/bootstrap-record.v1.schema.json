{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v1/bootstrap-record.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "kernel_version", "run_id", "request_id", "adapter_id", "canonical_item_id", "original_title", "task_start", "fixture_uri", "fixture_manifest_sha256", "status"],
  "properties": {
    "schema_name": {"const": "bootstrap-record"},
    "schema_version": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/schema_version"},
    "kernel_version": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/kernel_version"},
    "run_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/run_id"},
    "request_id": {"type": "string", "minLength": 1},
    "adapter_id": {"const": "fixture"},
    "canonical_item_id": {"type": "string", "minLength": 1},
    "original_title": {"type": "string", "minLength": 1},
    "task_start": {"type": "string", "format": "date-time"},
    "fixture_uri": {"type": "string", "pattern": "^fixture://"},
    "fixture_manifest_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "status": {"const": "probe_complete"}
  }
}
