{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v1/orphaned-filesystem-commit-report.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "kernel_version",
    "operation_id",
    "selected_backup_id",
    "classification",
    "gaps",
    "global_mutation_blocked",
    "manual_recovery_required"
  ],
  "properties": {
    "schema_name": {"const": "orphaned-filesystem-commit-report"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "operation_id": {"type": "string", "pattern": "^restore-[0-9a-f]{32}$"},
    "selected_backup_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "classification": {"const": "orphaned_filesystem_commit"},
    "gaps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://video2pdf.local/schemas/video-workflow/v1/control-store-recovery-report.v1.schema.json#/$defs/recovery_gap"
      },
      "contains": {
        "type": "object",
        "properties": {"classification": {"const": "orphaned_filesystem_commit"}},
        "required": ["classification"]
      },
      "minContains": 1
    },
    "global_mutation_blocked": {"const": true},
    "manual_recovery_required": {"const": true}
  }
}
