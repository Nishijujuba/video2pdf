{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v1/recorded-provider-package.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_name",
    "schema_version",
    "kernel_version",
    "recording_id",
    "canonical_platform",
    "adapter",
    "commands"
  ],
  "properties": {
    "$schema": {
      "const": "https://video2pdf.local/schemas/video-workflow/v1/recorded-provider-package.v1.schema.json"
    },
    "schema_name": {"const": "recorded-provider-package"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "recording_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,127}$"
    },
    "canonical_platform": {"enum": ["bilibili", "youtube"]},
    "adapter": {"$ref": "#/$defs/adapter"},
    "commands": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {"$ref": "#/$defs/command"}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"canonical_platform": {"const": "bilibili"}},
        "required": ["canonical_platform"]
      },
      "then": {
        "properties": {
          "adapter": {
            "const": {
              "id": "bilibili-yt-dlp.v1",
              "contract_version": "1.0.0"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"canonical_platform": {"const": "youtube"}},
        "required": ["canonical_platform"]
      },
      "then": {
        "properties": {
          "adapter": {
            "const": {
              "id": "youtube-yt-dlp.v1",
              "contract_version": "1.0.0"
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "contract_version"],
      "properties": {
        "id": {"enum": ["bilibili-yt-dlp.v1", "youtube-yt-dlp.v1"]},
        "contract_version": {"const": "1.0.0"}
      }
    },
    "stdoutFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^stdout/(?!(?:.*?/)?\\.\\.?/)(?!.*\\\\)[^\\r\\n]+$"
        },
        "sha256": {
          "$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"
        }
      }
    },
    "stderrFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^stderr/(?!(?:.*?/)?\\.\\.?/)(?!.*\\\\)[^\\r\\n]+$"
        },
        "sha256": {
          "$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt_relative_path", "fixture", "sha256"],
      "properties": {
        "attempt_relative_path": {
          "type": "string",
          "pattern": "^(?!(?:.*?/)?\\.\\.?/)(?!.*\\\\)[^/\\r\\n][^\\r\\n]*$"
        },
        "fixture": {
          "type": "string",
          "pattern": "^outputs/(?!(?:.*?/)?\\.\\.?/)(?!.*\\\\)[^\\r\\n]+$"
        },
        "sha256": {
          "$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "argv",
        "returncode",
        "stdout",
        "stderr",
        "outputs"
      ],
      "properties": {
        "operation": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{0,63}$"
        },
        "argv": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {"type": "string", "minLength": 1, "maxLength": 2000}
        },
        "returncode": {"type": "integer"},
        "stdout": {"$ref": "#/$defs/stdoutFile"},
        "stderr": {"$ref": "#/$defs/stderrFile"},
        "outputs": {
          "type": "array",
          "maxItems": 32,
          "items": {"$ref": "#/$defs/output"}
        }
      }
    }
  }
}
