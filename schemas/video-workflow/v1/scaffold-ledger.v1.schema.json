{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v1/scaffold-ledger.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "kernel_version", "run_id", "scaffold_version", "directories"],
  "properties": {
    "schema_name": {"const": "scaffold-ledger"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "run_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/run_id"},
    "scaffold_version": {"const": "1.0.0"},
    "directories": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["path", "created_by"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "created_by": {"const": "kernel:init-run"}
        }
      }
    }
  }
}
