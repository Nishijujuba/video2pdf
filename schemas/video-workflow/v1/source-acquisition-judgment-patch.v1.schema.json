{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v1/source-acquisition-judgment-patch.v1.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_name", "schema_version", "kernel_version", "task_id", "attempt_id", "task_envelope_sha256", "source_manifest_sha256", "judgment"],
  "properties": {
    "schema_name": {"const": "source-acquisition-judgment-patch"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "task_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "attempt_id": {"type": "string", "pattern": "^[0-9a-f]{24}$"},
    "task_envelope_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "source_manifest_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "judgment": {
      "type": "object", "additionalProperties": false,
      "required": ["selected_subtitle_track", "whisper_fallback", "known_gaps"],
      "properties": {
        "selected_subtitle_track": {"type": "string", "minLength": 1, "maxLength": 128},
        "whisper_fallback": {
          "type": "object", "additionalProperties": false,
          "required": ["choice", "rationale"],
          "properties": {
            "choice": {"enum": ["not_required", "use_whisper", "unavailable"]},
            "rationale": {"type": "string", "minLength": 1, "maxLength": 2000}
          }
        },
        "known_gaps": {
          "type": "array", "maxItems": 32,
          "items": {"type": "string", "minLength": 1, "maxLength": 1000}
        }
      }
    }
  }
}
