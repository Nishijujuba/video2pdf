{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v1/source-candidate-inventory.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "kernel_version",
    "run_id",
    "acquisition_id",
    "source_epoch",
    "mode",
    "adapter",
    "canonical_platform",
    "canonical_item_id",
    "source_identity_scheme",
    "source_identity",
    "provider",
    "authentication_classification",
    "policy_binding",
    "source_metadata",
    "commands",
    "candidates",
    "import_binding",
    "status"
  ],
  "properties": {
    "schema_name": {"const": "source-candidate-inventory"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "run_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/run_id"},
    "acquisition_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "source_epoch": {"type": "integer", "minimum": 1},
    "mode": {"enum": ["fresh_download", "verified_import"]},
    "adapter": {"$ref": "#/$defs/adapter"},
    "canonical_platform": {"enum": ["bilibili", "youtube"]},
    "canonical_item_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "source_identity_scheme": {"const": "canonical-platform-item-v1"},
    "source_identity": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "provider": {"$ref": "#/$defs/provider"},
    "authentication_classification": {"$ref": "#/$defs/authenticationClassification"},
    "policy_binding": {"$ref": "#/$defs/policyBinding"},
    "source_metadata": {"$ref": "#/$defs/sourceMetadata"},
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/command"}
    },
    "candidates": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "#/$defs/candidate"}
    },
    "import_binding": {
      "anyOf": [
        {"type": "null"},
        {"$ref": "#/$defs/importBinding"}
      ]
    },
    "status": {"const": "candidates_ready"}
  },
  "$defs": {
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "contract_version"],
      "properties": {
        "id": {"enum": ["bilibili", "youtube"]},
        "contract_version": {"const": "1.0.0"}
      }
    },
    "toolVersion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "maxLength": 128},
        "version": {"type": "string", "minLength": 1, "maxLength": 256}
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "recording_sha256", "tool_versions"],
      "properties": {
        "kind": {"enum": ["live", "recorded_fixture", "verified_import"]},
        "recording_sha256": {
          "anyOf": [
            {"type": "null"},
            {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
          ]
        },
        "tool_versions": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/toolVersion"}
        }
      }
    },
    "authenticationClassification": {
      "enum": [
        "not_applicable",
        "anonymous",
        "cookie_accepted",
        "cookie_missing",
        "cookie_unreadable",
        "cookie_rejected",
        "cookie_expired"
      ]
    },
    "policyBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "version",
        "sha256",
        "content_classification",
        "subtitle_language_priority",
        "whisper_allowed"
      ],
      "properties": {
        "policy_id": {"const": "source-acquisition-policy"},
        "version": {"const": "1.0.0"},
        "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
        "content_classification": {"enum": ["general", "language_learning"]},
        "subtitle_language_priority": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 64}
        },
        "whisper_allowed": {"type": "boolean"}
      }
    },
    "sourceMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["original_title", "duration_seconds"],
      "properties": {
        "original_title": {"type": "string", "minLength": 1, "maxLength": 2000},
        "duration_seconds": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "purpose",
        "command_argv_redacted",
        "exit_classification",
        "sanitized_log_sha256"
      ],
      "properties": {
        "command_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"},
        "purpose": {"enum": ["metadata_probe", "subtitle_inventory", "format_inventory", "download", "technical_probe", "verified_import_validation"]},
        "command_argv_redacted": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1, "maxLength": 2000}
        },
        "exit_classification": {"const": "success"},
        "sanitized_log_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
      }
    },
    "technicalProbe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "duration_seconds", "stream_types", "codec_names"],
      "properties": {
        "status": {"const": "pass"},
        "duration_seconds": {
          "anyOf": [
            {"type": "null"},
            {"type": "number", "exclusiveMinimum": 0}
          ]
        },
        "stream_types": {
          "type": "array",
          "uniqueItems": true,
          "items": {"enum": ["metadata", "image", "video", "audio", "subtitle", "transcript"]}
        },
        "codec_names": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 128}
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "role",
        "staged_path",
        "media_type",
        "sha256",
        "size_bytes",
        "origin",
        "language",
        "subtitle_kind",
        "technical_probe"
      ],
      "properties": {
        "candidate_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
        "role": {"enum": ["metadata", "cover", "video", "audio", "subtitle", "transcript"]},
        "staged_path": {"type": "string", "minLength": 1},
        "media_type": {"type": "string", "minLength": 1, "maxLength": 256},
        "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
        "size_bytes": {"type": "integer", "minimum": 1},
        "origin": {"enum": ["platform_download", "verified_import"]},
        "language": {
          "anyOf": [
            {"type": "null"},
            {"type": "string", "minLength": 1, "maxLength": 64}
          ]
        },
        "subtitle_kind": {
          "anyOf": [
            {"type": "null"},
            {"enum": ["manual", "automatic", "transcript"]}
          ]
        },
        "technical_probe": {"$ref": "#/$defs/technicalProbe"}
      }
    },
    "validationEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "evidence_sha256"],
      "properties": {
        "status": {"const": "pass"},
        "evidence_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
      }
    },
    "importBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prior_run_id",
        "prior_source_manifest_sha256",
        "prior_source_identity",
        "prior_source_version",
        "validation"
      ],
      "properties": {
        "prior_run_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/run_id"},
        "prior_source_manifest_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
        "prior_source_identity": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
        "prior_source_version": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "canonical_identity",
            "schema_compatibility",
            "artifact_fingerprints",
            "subtitle_policy",
            "technical_properties",
            "source_quality",
            "original_only"
          ],
          "properties": {
            "canonical_identity": {"$ref": "#/$defs/validationEvidence"},
            "schema_compatibility": {"$ref": "#/$defs/validationEvidence"},
            "artifact_fingerprints": {"$ref": "#/$defs/validationEvidence"},
            "subtitle_policy": {"$ref": "#/$defs/validationEvidence"},
            "technical_properties": {"$ref": "#/$defs/validationEvidence"},
            "source_quality": {"$ref": "#/$defs/validationEvidence"},
            "original_only": {"$ref": "#/$defs/validationEvidence"}
          }
        }
      }
    }
  }
}
