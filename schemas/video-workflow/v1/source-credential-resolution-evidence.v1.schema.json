{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v1/source-credential-resolution-evidence.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_name",
    "schema_version",
    "kernel_version",
    "run_id",
    "source_epoch",
    "canonical_platform",
    "resource_class",
    "breaker_key",
    "breaker_updated_seq",
    "blocker_evidence_sha256",
    "authentication_classification",
    "credential_reference",
    "probe_kind",
    "probe_command_argv_redacted",
    "provider_exit_code",
    "credential_probe_outcome",
    "provider_result_sha256",
    "sanitized_log_sha256",
    "verified_at"
  ],
  "properties": {
    "$schema": {
      "const": "https://video2pdf.local/schemas/video-workflow/v1/source-credential-resolution-evidence.v1.schema.json"
    },
    "schema_name": {"const": "source-credential-resolution-evidence"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "run_id": {
      "$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/run_id"
    },
    "source_epoch": {"type": "integer", "minimum": 1},
    "canonical_platform": {"enum": ["bilibili", "youtube"]},
    "resource_class": {"enum": ["bilibili_download", "youtube_download"]},
    "breaker_key": {
      "type": "string",
      "pattern": "^platform:(bilibili|youtube):(bilibili_download|youtube_download)$"
    },
    "breaker_updated_seq": {"type": "integer", "minimum": 1},
    "blocker_evidence_sha256": {
      "$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"
    },
    "authentication_classification": {"const": "cookie_accepted"},
    "credential_reference": {"const": "<localized-cookie-file>"},
    "probe_kind": {"const": "provider_authentication_probe"},
    "probe_command_argv_redacted": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {"type": "string", "minLength": 1, "maxLength": 512}
    },
    "provider_exit_code": {"const": 0},
    "credential_probe_outcome": {"const": "accepted"},
    "provider_result_sha256": {
      "$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"
    },
    "sanitized_log_sha256": {
      "$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"
    },
    "verified_at": {"type": "string", "format": "date-time"}
  }
}
