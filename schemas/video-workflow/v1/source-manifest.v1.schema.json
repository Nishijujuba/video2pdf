{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v1/source-manifest.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "kernel_version", "run_id", "mode", "adapter_id", "canonical_item_id", "fixture_manifest_sha256", "artifacts"],
  "properties": {
    "schema_name": {"const": "source-manifest"},
    "schema_version": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/schema_version"},
    "kernel_version": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/kernel_version"},
    "run_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/run_id"},
    "mode": {"const": "verified_import"},
    "adapter_id": {"const": "fixture"},
    "canonical_item_id": {"type": "string", "minLength": 1},
    "fixture_manifest_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "artifacts": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["logical_id", "path", "media_type", "sha256", "size_bytes"],
        "properties": {
          "logical_id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "pattern": "^source/"},
          "media_type": {"type": "string", "minLength": 1},
          "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
          "size_bytes": {"type": "integer", "minimum": 1}
        }
      }
    }
  }
}
