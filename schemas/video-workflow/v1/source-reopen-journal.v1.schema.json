{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v1/source-reopen-journal.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "kernel_version",
    "intent_id",
    "run_id",
    "reason",
    "prior_source_epoch",
    "expected_run_revision",
    "prior_run_record_sha256",
    "replacement_run_record_sha256",
    "replacement_run_record",
    "source_manifest_sha256",
    "coordination_record_path",
    "journal_path",
    "preservations",
    "state"
  ],
  "properties": {
    "schema_name": {"const": "source-reopen-journal"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "intent_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "run_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/run_id"},
    "reason": {"type": "string", "minLength": 1, "maxLength": 2000, "pattern": "\\S"},
    "prior_source_epoch": {"type": "integer", "minimum": 1},
    "expected_run_revision": {"type": "integer", "minimum": 1},
    "prior_run_record_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "replacement_run_record_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "replacement_run_record": {"$ref": "https://video2pdf.local/schemas/video-workflow/v3/run-record.v3.schema.json"},
    "source_manifest_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "coordination_record_path": {"const": "workflow/run.json"},
    "journal_path": {"type": "string", "minLength": 1},
    "preservations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {"$ref": "#/$defs/preservation"}
    },
    "state": {
      "enum": ["PREPARED", "SOURCE_PRESERVED", "RECORD_COMMITTED", "COMMITTED"]
    }
  },
  "$defs": {
    "preservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logical_id",
        "kind",
        "current_path",
        "preservation_path",
        "evidence_path",
        "expected_sha256"
      ],
      "properties": {
        "logical_id": {
          "enum": [
            "source_package",
            "source_candidates",
            "source_candidate_inventory",
            "source_acquisition_decision_skeleton",
            "source_transcription",
            "source_acquisition_decision"
          ]
        },
        "kind": {"enum": ["source_tree", "candidate_tree", "control_file"]},
        "current_path": {"type": "string", "minLength": 1},
        "preservation_path": {"type": "string", "minLength": 1},
        "evidence_path": {
          "anyOf": [
            {"type": "null"},
            {"type": "string", "minLength": 1}
          ]
        },
        "expected_sha256": {
          "anyOf": [
            {"type": "null"},
            {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
          ]
        }
      }
    }
  }
}
