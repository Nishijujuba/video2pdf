{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v1/task-completion-record.v1.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_name", "schema_version", "kernel_version", "task_id", "attempt_id", "claim_generation", "task_envelope_sha256", "validated_authority_revision", "validated_run_record_sha256", "validated_inputs", "outputs", "gate_status", "validated_at"],
  "properties": {
    "schema_name": {"const": "task-completion-record"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "task_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "attempt_id": {"type": "string", "pattern": "^[0-9a-f]{24}$"},
    "claim_generation": {"type": "integer", "minimum": 1},
    "task_envelope_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "validated_authority_revision": {"type": "integer", "minimum": 1},
    "validated_run_record_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "validated_inputs": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["logical_id", "generation", "sha256"],
        "properties": {
          "logical_id": {"type": "string", "minLength": 1},
          "generation": {"type": "integer", "minimum": 1},
          "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
        }
      }
    },
    "outputs": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["logical_id", "attempt_path", "canonical_path", "sha256"],
        "properties": {
          "logical_id": {"type": "string", "minLength": 1},
          "attempt_path": {"type": "string", "minLength": 1},
          "canonical_path": {"type": "string", "minLength": 1},
          "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
        }
      }
    },
    "gate_status": {"const": "pass"},
    "validated_at": {"type": "string", "format": "date-time"}
  }
}
