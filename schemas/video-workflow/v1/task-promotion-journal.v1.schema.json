{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v1/task-promotion-journal.v1.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_name", "schema_version", "kernel_version", "intent_id", "run_id", "task_id", "attempt_id", "claim_generation", "expected_run_revision", "prior_run_record_sha256", "replacement_run_record_sha256", "coordination_record_path", "outputs", "state"],
  "properties": {
    "schema_name": {"const": "task-promotion-journal"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "intent_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "run_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/run_id"},
    "task_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "attempt_id": {"type": "string", "pattern": "^[0-9a-f]{24}$"},
    "claim_generation": {"type": "integer", "minimum": 1},
    "expected_run_revision": {"type": "integer", "minimum": 1},
    "prior_run_record_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "replacement_run_record_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "coordination_record_path": {"const": "workflow/run.json"},
    "outputs": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["logical_id", "attempt_path", "canonical_path", "sha256", "prior_sha256", "preservation_path"],
        "properties": {
          "logical_id": {"type": "string", "minLength": 1},
          "attempt_path": {"type": "string", "minLength": 1},
          "canonical_path": {"type": "string", "minLength": 1},
          "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
          "prior_sha256": {"anyOf": [{"type": "null"}, {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}]},
          "preservation_path": {"type": "string", "minLength": 1}
        }
      }
    },
    "state": {"const": "PREPARED"}
  }
}
