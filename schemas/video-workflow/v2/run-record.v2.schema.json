{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v2/run-record.v2.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_name", "schema_version", "kernel_version", "scaffold_version", "run_id", "request_id", "platform_adapter", "canonical_platform", "canonical_item_id", "source_identity", "original_title", "normalized_title", "task_start", "output_path", "deliverable_version", "version_basis", "source_acquisition_mode", "phase", "initialization_intent_id", "coordination_revision", "last_mutation_intent_id", "artifact_plan", "artifact_generations", "checkpoint_dependencies", "checkpoints"],
  "properties": {
    "schema_name": {"const": "run-record"},
    "schema_version": {"const": "2.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "scaffold_version": {"const": "1.0.0"},
    "run_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/run_id"},
    "request_id": {"type": "string", "minLength": 1},
    "platform_adapter": {"const": "fixture"},
    "canonical_platform": {"const": "fixture"},
    "canonical_item_id": {"type": "string", "minLength": 1},
    "source_identity": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "original_title": {"type": "string", "minLength": 1},
    "normalized_title": {"type": "string", "minLength": 1},
    "task_start": {"type": "string", "format": "date-time"},
    "output_path": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/absolute_path"},
    "deliverable_version": {"const": 1},
    "version_basis": {"const": "source_only"},
    "source_acquisition_mode": {"const": "verified_import"},
    "phase": {"const": "source_ready"},
    "initialization_intent_id": {"type": "string", "minLength": 1},
    "coordination_revision": {"type": "integer", "minimum": 2},
    "last_mutation_intent_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "artifact_plan": {"const": "workflow/artifact-plan.json"},
    "artifact_generations": {
      "type": "object", "additionalProperties": false,
      "required": ["source_manifest", "source_acquisition_decision"],
      "properties": {
        "source_manifest": {
          "type": "object", "additionalProperties": false,
          "required": ["path", "generation", "sha256", "producer"],
          "properties": {
            "path": {"const": "source/manifest.json"},
            "generation": {"const": 1},
            "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
            "producer": {"const": "kernel:verified-import"}
          }
        },
        "source_acquisition_decision": {
          "type": "object", "additionalProperties": false,
          "required": ["path", "generation", "sha256", "producer", "committed_at"],
          "properties": {
            "path": {"const": "workflow/source-acquisition-judgment-patch.json"},
            "generation": {"type": "integer", "minimum": 1},
            "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
            "producer": {"type": "string", "pattern": "^task:[0-9a-f]{32}/[0-9a-f]{24}$"},
            "committed_at": {"type": "string", "format": "date-time"}
          }
        }
      }
    },
    "checkpoint_dependencies": {
      "const": {"source_acquisition_decision_ready": ["source_ready"]}
    },
    "checkpoints": {
      "type": "object", "additionalProperties": false,
      "required": ["source_ready", "source_acquisition_decision_ready"],
      "properties": {
        "source_ready": {
          "type": "object", "additionalProperties": false,
          "required": ["status", "artifact_generations", "evidence_sha256"],
          "properties": {
            "status": {"enum": ["current", "stale"]},
            "artifact_generations": {"const": {"source_manifest": 1}},
            "evidence_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
          }
        },
        "source_acquisition_decision_ready": {
          "type": "object", "additionalProperties": false,
          "required": ["status", "artifact_generations", "evidence_sha256"],
          "properties": {
            "status": {"enum": ["current", "stale"]},
            "artifact_generations": {
              "type": "object", "additionalProperties": false,
              "required": ["source_manifest", "source_acquisition_decision"],
              "properties": {
                "source_manifest": {"const": 1},
                "source_acquisition_decision": {"type": "integer", "minimum": 1}
              }
            },
            "evidence_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
          }
        }
      }
    }
  }
}
