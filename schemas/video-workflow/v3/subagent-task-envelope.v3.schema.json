{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v3/subagent-task-envelope.v3.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "kernel_version",
    "task_id",
    "logical_task_key",
    "role",
    "task_stage",
    "platform",
    "source_epoch",
    "authority_binding",
    "prepared_at",
    "task_root_path",
    "input_artifacts",
    "allowed_read_paths",
    "protected_run_snapshot",
    "write_set",
    "required_outputs",
    "generated_prompt",
    "bounded_semantic_fields",
    "whisper_audio_candidate",
    "resource_request",
    "fairness_group_id"
  ],
  "properties": {
    "schema_name": {"const": "subagent-task-envelope"},
    "schema_version": {"const": "3.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "task_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "logical_task_key": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,95}$"},
    "role": {"const": "source_acquisition"},
    "task_stage": {"enum": ["provider_acquisition", "semantic_judgment", "whisper_transcription"]},
    "platform": {"enum": ["bilibili", "youtube"]},
    "source_epoch": {"type": "integer", "minimum": 1},
    "authority_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "run_id", "expected_coordination_revision", "target_checkpoint"],
      "properties": {
        "kind": {"const": "kernel_run"},
        "run_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/run_id"},
        "expected_coordination_revision": {"type": "integer", "minimum": 1},
        "target_checkpoint": {"enum": ["source_candidates_ready", "source_acquisition_decision_ready", "source_ready"]}
      }
    },
    "prepared_at": {"type": "string", "format": "date-time"},
    "task_root_path": {"type": "string", "minLength": 1},
    "input_artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {"$ref": "#/$defs/inputArtifact"}
    },
    "allowed_read_paths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "protected_run_snapshot": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/protectedPath"}
    },
    "write_set": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "required_outputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": {"$ref": "#/$defs/requiredOutput"}
    },
    "generated_prompt": {
      "anyOf": [
        {"type": "null"},
        {"$ref": "#/$defs/generatedPrompt"}
      ]
    },
    "bounded_semantic_fields": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "whisper_audio_candidate": {
      "anyOf": [
        {"type": "null"},
        {"$ref": "#/$defs/whisperAudioCandidate"}
      ]
    },
    "resource_request": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["bilibili_download", "youtube_download", "codex_semantic", "whisper"]}
    },
    "fairness_group_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "batch_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"}
  },
  "$defs": {
    "inputArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_id", "path", "generation", "sha256"],
      "properties": {
        "logical_id": {"enum": ["bootstrap_record", "source_candidate_inventory", "source_acquisition_decision_skeleton", "source_acquisition_decision"]},
        "path": {"type": "string", "minLength": 1},
        "generation": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
      }
    },
    "protectedPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
      }
    },
    "requiredOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logical_id",
        "attempt_relative_path",
        "canonical_path",
        "schema_name",
        "schema_version",
        "expected_prior_generation",
        "expected_prior_sha256"
      ],
      "properties": {
        "logical_id": {"enum": ["source_candidate_inventory", "source_acquisition_decision_skeleton", "source_acquisition_decision", "source_transcription"]},
        "attempt_relative_path": {"type": "string", "minLength": 1},
        "canonical_path": {"type": "string", "minLength": 1},
        "schema_name": {"enum": ["source-candidate-inventory", "source-acquisition-decision-skeleton", "source-acquisition-judgment-patch", "source-transcription-srt"]},
        "schema_version": {"enum": ["1.0.0", "2.0.0"]},
        "expected_prior_generation": {
          "anyOf": [
            {"type": "null"},
            {"type": "integer", "minimum": 1}
          ]
        },
        "expected_prior_sha256": {
          "anyOf": [
            {"type": "null"},
            {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
          ]
        }
      }
    },
    "promptSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "version", "path", "sha256"],
      "properties": {
        "identity": {"type": "string", "minLength": 1},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
      }
    },
    "generatedPrompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "role_template", "platform_overlay"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
        "role_template": {"$ref": "#/$defs/promptSource"},
        "platform_overlay": {"$ref": "#/$defs/promptSource"}
      }
    },
    "whisperAudioCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "staged_path", "sha256"],
      "properties": {
        "candidate_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
        "staged_path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
      }
    }
  }
}
