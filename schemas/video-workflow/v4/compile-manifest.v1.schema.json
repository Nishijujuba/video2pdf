{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v4/compile-manifest.v1.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_name", "schema_version", "kernel_version", "run_id", "mode", "delivery_authority", "integration_manifest_generation", "runtime_policy_sha256", "dependency_discovery_policy_version", "entries"],
  "properties": {
    "schema_name": {"const": "compile-manifest"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "run_id": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/run_id"},
    "mode": {"const": "diagnostic"},
    "delivery_authority": {"const": false},
    "integration_manifest_generation": {"type": "object", "additionalProperties": false, "required": ["generation", "sha256"], "properties": {"generation": {"type": "integer", "minimum": 1}, "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}}},
    "runtime_policy_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "dependency_discovery_policy_version": {"const": "recorder-closure-v1"},
    "entries": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/entry"}}
  },
  "$defs": {
    "entry": {
      "type": "object", "additionalProperties": false,
      "required": ["logical_id", "generation", "sha256", "size", "producer", "source_path", "staging_path", "role", "media_type", "required"],
      "properties": {
        "logical_id": {"type": "string", "minLength": 1},
        "generation": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
        "size": {"type": "integer", "minimum": 0},
        "producer": {"type": "string", "minLength": 1},
        "source_path": {"type": "string", "minLength": 1},
        "staging_path": {"type": "string", "minLength": 1},
        "role": {"enum": ["entry_tex", "section_tex", "figure", "bibliography", "local_class", "local_style", "local_font", "support"]},
        "media_type": {"type": "string", "pattern": "^[a-z0-9][a-z0-9.+-]+/[a-z0-9][a-z0-9.+-]+$"},
        "required": {"type": "boolean"}
      }
    }
  }
}
