{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v4/compile-runtime-policy.v1.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_name", "schema_version", "kernel_version", "policy_id", "policy_version", "runtime_family", "engine", "package_inventory", "allowed_packages", "allowed_runtime_roots", "system_fonts", "automatic_package_install", "shell_escape", "dependency_discovery_policy_version", "policy_sha256"],
  "properties": {
    "schema_name": {"const": "compile-runtime-policy"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "policy_id": {"type": "string", "minLength": 1},
    "policy_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "runtime_family": {"const": "miktex"},
    "engine": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "version", "executable", "sha256", "prefix_args", "prefix_file_fingerprints"],
      "properties": {
        "name": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1},
        "executable": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
        "prefix_args": {"type": "array", "items": {"type": "string"}},
        "prefix_file_fingerprints": {"type": "array", "items": {"$ref": "https://video2pdf.local/schemas/video-workflow/v4/production-common.v1.schema.json#/$defs/fingerprintedPath"}}
      }
    },
    "package_inventory": {"type": "object", "additionalProperties": false, "required": ["version", "path", "sha256"], "properties": {"version": {"type": "string", "minLength": 1}, "path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}}},
    "allowed_packages": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"}},
    "allowed_runtime_roots": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "system_fonts": {"type": "array", "minItems": 1, "items": {"$ref": "https://video2pdf.local/schemas/video-workflow/v4/production-common.v1.schema.json#/$defs/fingerprintedPath"}},
    "automatic_package_install": {"const": false},
    "shell_escape": {"const": false},
    "dependency_discovery_policy_version": {"const": "recorder-closure-v1"},
    "policy_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
  }
}
