{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v4/diagnostic-compile-report.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "kernel_version", "mode", "status", "delivery_authority", "compile_manifest_path", "compile_manifest_sha256", "runtime_policy_sha256", "engine", "invocation", "executed_passes", "generated_outputs", "dependency_closure", "pdf"],
  "properties": {
    "schema_name": {"const": "diagnostic-compile-report"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "mode": {"const": "diagnostic"},
    "status": {"const": "pass"},
    "delivery_authority": {"const": false},
    "compile_manifest_path": {"type": "string", "minLength": 1},
    "compile_manifest_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "runtime_policy_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "engine": {"$ref": "#/$defs/engine"},
    "invocation": {"$ref": "#/$defs/invocation"},
    "executed_passes": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["pass", "exit_code", "recorder_sha256"], "properties": {"pass": {"type": "integer", "minimum": 1}, "exit_code": {"const": 0}, "recorder_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}}}},
    "generated_outputs": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}, "size": {"type": "integer", "minimum": 1}}}},
    "dependency_closure": {"$ref": "#/$defs/dependencyClosure"},
    "pdf": {"$ref": "#/$defs/pdf"}
  },
  "$defs": {
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "sha256"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
      }
    },
    "invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["automatic_package_install", "shell_escape", "recorder", "argv"],
      "properties": {
        "automatic_package_install": {"const": false},
        "shell_escape": {"const": false},
        "recorder": {"const": true},
        "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "dependencyClosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["complete", "inputs", "recorder_sha256"],
      "properties": {
        "complete": {"const": true},
        "inputs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/observedInput"}},
        "recorder_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}
      }
    },
    "observedInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "classification"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "classification": {"enum": ["manifest_entry", "registered_system_font", "registered_runtime_dependency", "attempt_generated_auxiliary"]}
      }
    },
    "pdf": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
        "size": {"type": "integer", "minimum": 1}
      }
    }
  }
}
