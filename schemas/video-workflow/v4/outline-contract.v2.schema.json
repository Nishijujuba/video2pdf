{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://video2pdf.local/schemas/video-workflow/v4/outline-contract.v2.schema.json",
  "type":"object","additionalProperties":false,
  "required":["schema_name","schema_version","kernel_version","article_title","terminology","sections","required_figure_slots","compile_support"],
  "properties":{
    "schema_name":{"const":"outline-contract"},"schema_version":{"const":"2.0.0"},"kernel_version":{"const":"2.0.0"},
    "article_title":{"type":"string","minLength":1},
    "terminology":{"type":"array","minItems":1,"items":{"type":"object","additionalProperties":false,"required":["term","definition"],"properties":{"term":{"type":"string","minLength":1},"definition":{"type":"string","minLength":1}}}},
    "sections":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"object","additionalProperties":false,"required":["section_id","title"],"properties":{"section_id":{"type":"string","pattern":"^section_[0-9]{2}$"},"title":{"type":"string","minLength":1}}}},
    "required_figure_slots":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"object","additionalProperties":false,"required":["slot_id","section_id","teaching_purpose","placement_marker"],"properties":{"slot_id":{"type":"string","pattern":"^figure_[a-z0-9_-]+$"},"section_id":{"type":"string","pattern":"^section_[0-9]{2}$"},"teaching_purpose":{"type":"string","minLength":1},"placement_marker":{"type":"string","pattern":"^% FIGURE_SLOT:figure_[a-z0-9_-]+$"}}}},
    "compile_support":{"type":"object","additionalProperties":false,"required":["document_class","class_content","style_name","style_content","bibliography_name","bibliography_content"],"properties":{"document_class":{"type":"string","pattern":"^[A-Za-z0-9_-]+$"},"class_content":{"type":"string","minLength":1},"style_name":{"type":"string","pattern":"^[A-Za-z0-9_-]+$"},"style_content":{"type":"string","minLength":1},"bibliography_name":{"type":"string","pattern":"^[A-Za-z0-9_-]+\\.bib$"},"bibliography_content":{"type":"string","minLength":1}}}
  }
}
