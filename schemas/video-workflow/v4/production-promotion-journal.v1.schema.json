{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v4/production-promotion-journal.v1.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_name", "schema_version", "kernel_version", "intent_id", "task_id", "attempt_id", "state", "entries"],
  "properties": {
    "schema_name": {"const": "production-promotion-journal"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "intent_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "task_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "attempt_id": {"type": "string", "pattern": "^[0-9a-f]{24}$"},
    "state": {"enum": ["prepared", "committed"]},
    "entries": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["source_sha256", "staged_path", "target_path"], "properties": {"source_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"}, "staged_path": {"type": "string", "minLength": 1}, "target_path": {"type": "string", "minLength": 1}}}}
  }
}
