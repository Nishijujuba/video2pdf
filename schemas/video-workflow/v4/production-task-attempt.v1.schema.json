{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video2pdf.local/schemas/video-workflow/v4/production-task-attempt.v1.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_name", "schema_version", "kernel_version", "task_id", "attempt_id", "claim_generation", "claim_token", "envelope_sha256", "outputs"],
  "properties": {
    "schema_name": {"const": "production-task-attempt"},
    "schema_version": {"const": "1.0.0"},
    "kernel_version": {"const": "2.0.0"},
    "task_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "attempt_id": {"type": "string", "pattern": "^[0-9a-f]{24}$"},
    "claim_generation": {"type": "integer", "minimum": 1},
    "claim_token": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "envelope_sha256": {"$ref": "https://video2pdf.local/schemas/video-workflow/v1/common.v1.schema.json#/$defs/sha256"},
    "outputs": {"type": "array", "minItems": 1, "items": {"$ref": "https://video2pdf.local/schemas/video-workflow/v4/production-common.v1.schema.json#/$defs/fingerprintedPath"}}
  }
}
