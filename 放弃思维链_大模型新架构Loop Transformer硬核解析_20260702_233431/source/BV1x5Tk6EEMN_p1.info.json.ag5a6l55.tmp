33&nbs=1&platform=pc&uipk=5&oi=1746716166&mid=43355747&og=cos&trid=6b76bedfeb1948e3908a9c9aa5609f8u&gen=playurlv3&os=cosovbv&upsig=4590dd303714fc0f67d80e88128fe7b3&uparams=e,deadline,nbs,platform,uipk,oi,mid,og,trid,gen,os&bvc=vod&nettype=0&bw=413521&lrs=0&buvid=8F4A755C-C261-42A4-6AD5-2A73E47AC87D66488infoc&build=0&dl=0&f=u_0_0&qn_dyeid=25fbcb6956fb8f69005246346a468545&agrr=0&orderid=0,2", "ext": "mp4", "fps": 29.962, "width": 1280, "height": 720, "vcodec": "avc1.640033", "acodec": "none", "dynamic_range": "SDR", "tbr": 413.148, "quality": 64, "format_id": "30064", "format": "720P 准高清", "protocol": "https", "video_ext": "mp4", "audio_ext": "none", "abr": 0, "vbr": 413.148, "resolution": "1280x720", "aspect_ratio": 1.78, "filesize_approx": 59342771, "http_headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8", "Accept-Language": "en-us,en;q=0.5", "Sec-Fetch-Mode": "navigate", "Referer": "https://www.bilibili.com/video/BV1x5Tk6EEMN/?buvid=Z8427A84BDF99B244B98A866C02B9CB42F9C&from_spmid=search.search-result.0.0&is_story_h5=false&mid=pcYGa8O5%2F2lqRf%2BRIKl0oQ%3D%3D&p=1&plat_id=116&share_from=ugc&share_medium=iphone&share_plat=ios&share_session_id=8ABD7F75-CC50-4246-B7FB-300CB9697712&share_source=COPY&share_tag=s_i&spmid=united.player-video-detail.0.0&timestamp=1783006285&unique_k=D2nUhxC&up_id=435076601"}}, {"url": "https://upos-sz-mirrorcosov.bilivideo.com/upgcxcode/50/24/39578632450/39578632450-1-30080.m4s?e=ig8euxZM2rNcNbdlhoNvNC8BqJIzNbfqXBvEqxTEto8BTrNvN0GvT90W5JZMkX_YN0MvXg8gNEV4NC8xNEV4N03eN0B5tZlqNxTEto8BTrNvNeZVuJ10Kj_g2UB02J0mN0B5tZlqNCNEto8BTrNvNC7MTX502C8f2jmMQJ6mqF2fka1mqx6gqj0eN0B599M=&os=cosovbv&og=ali&trid=6b76bedfeb1948e3908a9c9aa5609f8u&mid=43355747&deadline=1783013733&nbs=1&platform=pc&uipk=5&oi=1746716166&gen=playurlv3&upsig=b76d93e3d01bc57ecf52116ad11444d4&uparams=e,os,og,trid,mid,deadline,nbs,platform,uipk,oi,gen&bvc=vod&nettype=0&bw=841162&lrs=0&buvid=8F4A755C-C261-42A4-6AD5-2A73E47AC87D66488infoc&build=0&dl=0&f=u_0_0&qn_dyeid=25fbcb6956fb8f69005246346a468545&agrr=0&orderid=0,2", "ext": "mp4", "fps": 29.962, "width": 1920, "height": 1080, "vcodec": "avc1.640033", "acodec": "none", "dynamic_range": "SDR", "tbr": 840.424, "quality": 80, "format_id": "30080", "format": "1080P 高清", "protocol": "https", "video_ext": "mp4", "audio_ext": "none", "abr": 0, "vbr": 840.424, "resolution": "1920x1080", "aspect_ratio": 1.78, "filesize_approx": 120714826, "http_headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8", "Accept-Language": "en-us,en;q=0.5", "Sec-Fetch-Mode": "navigate", "Referer": "https://www.bilibili.com/video/BV1x5Tk6EEMN/?buvid=Z8427A84BDF99B244B98A866C02B9CB42F9C&from_spmid=search.search-result.0.0&is_story_h5=false&mid=pcYGa8O5%2F2lqRf%2BRIKl0oQ%3D%3D&p=1&plat_id=116&share_from=ugc&share_medium=iphone&share_plat=ios&share_session_id=8ABD7F75-CC50-4246-B7FB-300CB9697712&share_source=COPY&share_tag=s_i&spmid=united.player-video-detail.0.0&timestamp=1783006285&unique_k=D2nUhxC&up_id=435076601"}}, {"url": "https://upos-sz-mirrorcosov.bilivideo.com/upgcxcode/50/24/39578632450/39578632450-1-30112.m4s?e=ig8euxZM2rNcNbdlhoNvNC8BqJIzNbfqXBvEqxTEto8BTrNvN0GvT90W5JZMkX_YN0MvXg8gNEV4NC8xNEV4N03eN0B5tZlqNxTEto8BTrNvNeZVuJ10Kj_g2UB02J0mN0B5tZlqNCNEto8BTrNvNC7MTX502C8f2jmMQJ6mqF2fka1mqx6gqj0eN0B599M=&nbs=1&oi=1746716166&trid=6b76bedfeb1948e3908a9c9aa5609f8u&os=cosovbv&og=ali&mid=43355747&deadline=1783013733&platform=pc&uipk=5&gen=playurlv3&upsig=5d295077f429a58d2d756c717478a149&uparams=e,nbs,oi,trid,os,og,mid,deadline,platform,uipk,gen&bvc=vod&nettype=0&bw=1132796&lrs=0&build=0&dl=0&f=u_0_0&qn_dyeid=25fbcb6956fb8f69005246346a468545&agrr=0&buvid=8F4A755C-C261-42A4-6AD5-2A73E47AC87D66488infoc&orderid=0,2", "ext": "mp4", "fps": 29.962, "width": 1920, "height": 1080, "vcodec": "avc1.640033", "acodec": "none", "dynamic_range": "SDR", "tbr": 1131.809, "quality": 112, "format_id": "30112", "format": "1080P 高码率", "protocol": "https", "video_ext": "mp4", "audio_ext": "none", "abr": 0, "vbr": 1131.809, "resolution": "1920x1080", "aspect_ratio": 1.78, "filesize_approx": 162568093, "http_headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8", "Accept-Language": "en-us,en;q=0.5", "Sec-Fetch-Mode": "navigate", "Referer": "https://www.bilibili.com/video/BV1x5Tk6EEMN/?buvid=Z8427A84BDF99B244B98A866C02B9CB42F9C&from_spmid=search.search-result.0.0&is_story_h5=false&mid=pcYGa8O5%2F2lqRf%2BRIKl0oQ%3D%3D&p=1&plat_id=116&share_from=ugc&share_medium=iphone&share_plat=ios&share_session_id=8ABD7F75-CC50-4246-B7FB-300CB9697712&share_source=COPY&share_tag=s_i&spmid=united.player-video-detail.0.0&timestamp=1783006285&unique_k=D2nUhxC&up_id=435076601"}}], "duration": 1149.085, "subtitles": {"danmaku": [{"ext": "xml", "url": "https://comment.bilibili.com/39578632450.xml"}], "ai-zh": [{"ext": "srt", "data": "1\n00:00:00,040 --> 00:00:03,680\n你是否曾感受过优雅的推理模型是如何运作的\n\n2\n00:00:03,680 --> 00:00:03,800\n哦\n\n3\n00:00:03,800 --> 00:00:05,740\n我正在生成大量token进行思考\n\n4\n00:00:05,740 --> 00:00:07,280\n然后输出结果\n\n5\n00:00:07,280 --> 00:00:08,560\n并且如此高效以至于\n\n6\n00:00:08,560 --> 00:00:13,240\n如今几乎所有现有模型都在这样做以获得巨大性能提升\n\n7\n00:00:13,240 --> 00:00:15,420\n然而这仍是令人不满的解决方案\n\n8\n00:00:15,420 --> 00:00:17,600\n或许有时乞丐也能挑拣\n\n9\n00:00:17,600 --> 00:00:21,700\n因为测试时的计算是智能模型的必然结果\n\n10\n00:00:21,700 --> 00:00:24,580\n当你让模型在多条路径上推理时\n\n11\n00:00:24,580 --> 00:00:27,960\n就为其提供了优化和迭代改进的空间\n\n12\n00:00:27,960 --> 00:00:31,680\n思维链为Transformer提供了外化思考的空间\n\n13\n00:00:31,680 --> 00:00:33,840\n并用token模拟迭代过程\n\n14\n00:00:33,840 --> 00:00:35,960\n迄今为止效果极其出色\n\n15\n00:00:35,960 --> 00:00:37,840\n然而这确实让人不禁思考\n\n16\n00:00:37,840 --> 00:00:40,580\n为何推理和思维链能以这种方式实现\n\n17\n00:00:40,580 --> 00:00:42,680\n而非在推理时只是输出无意义token\n\n18\n00:00:42,680 --> 00:00:46,140\n为何研究人员不能开发出能天然思考的方法\n\n19\n00:00:46,140 --> 00:00:46,800\n或者说\n\n20\n00:00:46,800 --> 00:00:48,160\n以更紧凑的形式\n\n21\n00:00:48,160 --> 00:00:48,380\n嗯\n\n22\n00:00:48,380 --> 00:00:49,200\n在今天的视频中\n\n23\n00:00:49,200 --> 00:00:52,640\n让我们看看这个名为循环Transformer的新概念\n\n24\n00:00:52,640 --> 00:00:52,920\n其中\n\n25\n00:00:52,920 --> 00:00:55,420\n无需通过生成token进行测试时计算\n\n26\n00:00:55,420 --> 00:00:57,740\n而是通过循环Transformer层实现\n\n27\n00:00:57,740 --> 00:01:00,180\n这是人们普遍怀疑的一个猜想\n\n28\n00:01:00,180 --> 00:01:02,140\nClaude的Mythos正在后台使用\n\n29\n00:01:02,140 --> 00:01:06,940\n因其展现出超越以往模型的推理能力\n\n30\n00:01:06,940 --> 00:01:09,880\n特别是在图遍历BFS基准测试中\n\n31\n00:01:09,880 --> 00:01:12,420\n如果仔细思考架构设计\n\n32\n00:01:12,420 --> 00:01:13,300\n从结构上\n\n33\n00:01:13,300 --> 00:01:14,700\n是否应该优于\n\n34\n00:01:14,700 --> 00:01:15,440\ntoken级别\n\n35\n00:01:15,440 --> 00:01:19,660\n因为token级别需要将信息压缩为token再解压\n\n36\n00:01:19,660 --> 00:01:20,480\n完成思考过程\n\n37\n00:01:20,480 --> 00:01:22,340\n在深入探讨前\n\n38\n00:01:22,340 --> 00:01:23,880\n我们正讨论优雅性\n\n39\n00:01:23,880 --> 00:01:24,540\n模型微调\n\n40\n00:01:24,540 --> 00:01:26,180\n在裸金属GPU上训练AI模型\n\n41\n00:01:26,180 --> 00:01:27,860\n大概是你最后会想到的事\n\n42\n00:01:27,860 --> 00:01:31,120\n当需要处理容器运行时和Kubernetes等系统时\n\n43\n00:01:31,120 --> 00:01:36,200\n但今日赞助商Crusoe已将这一痛苦过程变得优雅\n\n44\n00:01:36,200 --> 00:01:38,060\n他们开发了名为无服务器的微调方案\n\n45\n00:01:38,060 --> 00:01:42,720\n帮助你定制深度海豚Gemma和GPSS等开源模型\n\n46\n00:01:42,720 --> 00:01:43,680\n更快更便捷\n\n47\n00:01:43,680 --> 00:01:46,500\n只需几行代码即可实现基于token的定价\n\n48\n00:01:46,500 --> 00:01:50,220\n即可在NVIDIA优化硬件上启动微调任务\n\n49\n00:01:50,220 --> 00:01:52,260\n无需处理GPU资源\n\n50\n00:01:52,260 --> 00:01:55,680\n你只需上传数据集，任务自动扩展\n\n51\n00:01:55,680 --> 00:01:56,660\n我喜欢的一点是\n\n52\n00:01:56,660 --> 00:01:58,520\n库奥的特点是它们并非黑箱\n\n53\n00:01:58,520 --> 00:02:00,280\n默认自带明确倾向性\n\n54\n00:02:00,280 --> 00:02:01,920\n智能预设助你快速起步\n\n55\n00:02:01,920 --> 00:02:03,160\n但设计上开放灵活\n\n56\n00:02:03,160 --> 00:02:05,500\n可针对独特场景调整设置\n\n57\n00:02:05,500 --> 00:02:08,940\n但最重要的是任务完成后\n\n58\n00:02:08,940 --> 00:02:11,500\n能以dot格式等便携形式获取原始权重\n\n59\n00:02:11,500 --> 00:02:12,200\n保存张量\n\n60\n00:02:12,200 --> 00:02:13,940\n所以别再浪费时间和资源\n\n61\n00:02:13,940 --> 00:02:17,560\n调试基础设施，开始真正部署模型\n\n62\n00:02:17,560 --> 00:02:22,240\n现在只需一个下午即可将定制模型从实验到生产\n\n63\n00:02:22,240 --> 00:02:23,000\n立即查看\n\n64\n00:02:23,000 --> 00:02:27,200\n通过描述下方链接获取早期访问权限，体验今日系列微调\n\n65\n00:02:27,200 --> 00:02:29,920\n感谢Crucial赞助本视频\n\n66\n00:02:29,920 --> 00:02:32,520\n即使只是推理能力的冰山一角\n\n67\n00:02:32,520 --> 00:02:34,860\n我们需要先衡量推理能力\n\n68\n00:02:34,860 --> 00:02:38,160\n才能证明模型改进的有效性\n\n69\n00:02:38,160 --> 00:02:38,540\n没错\n\n70\n00:02:38,540 --> 00:02:42,780\n最基础的推理可能表现为多跳推理\n\n71\n00:02:42,780 --> 00:02:43,380\n例如\n\n72\n00:02:43,380 --> 00:02:44,460\n谁是第44任总统的妻子\n\n73\n00:02:44,460 --> 00:02:47,400\n对于稍简单模型\n\n74\n00:02:47,400 --> 00:02:49,760\n无法直接映射到米歇尔·奥巴马\n\n75\n00:02:49,760 --> 00:02:54,260\n因为它需先识别第44任总统是巴拉克·奥巴马\n\n76\n00:02:54,260 --> 00:02:55,980\n并记住配偶姓名\n\n77\n00:02:55,980 --> 00:02:57,460\n即米歇尔·奥巴马\n\n78\n00:02:57,460 --> 00:02:59,580\n这基本是两次跳跃\n\n79\n00:02:59,580 --> 00:03:04,440\n每个跳跃获取或计算新信息\n\n80\n00:03:04,440 --> 00:03:06,400\n但为何这是推理？\n\n81\n00:03:06,400 --> 00:03:11,180\n单步问答通常通过模式匹配和记忆完成\n\n82\n00:03:11,180 --> 00:03:13,340\n因此大型语言模型更容易回答\n\n83\n00:03:13,340 --> 00:03:17,520\n然而多跳推理需要状态追踪和中间计算\n\n84\n00:03:17,520 --> 00:03:21,560\n因答案需从多知识源推断\n\n85\n00:03:21,560 --> 00:03:23,100\n难以直接记忆\n\n86\n00:03:23,100 --> 00:03:27,880\n这成为逻辑推断能力的简单指标\n\n87\n00:03:27,880 --> 00:03:31,340\n为研究者提供符号推理和关系推理基准\n\n88\n00:03:31,340 --> 00:03:36,420\n尤其作为非推理模型或基础Transformer的早期基线\n\n89\n00:03:36,420 --> 00:03:39,240\n需一次性完成所有步骤\n\n90\n00:03:39,240 --> 00:03:41,380\n若未获取答案\n\n91\n00:03:41,380 --> 00:03:42,640\n就会错失机会\n\n92\n00:03:42,640 --> 00:03:44,620\n随着跳跃次数增加\n\n93\n00:03:44,620 --> 00:03:48,060\n模型需模拟更深层计算\n\n94\n00:03:48,060 --> 00:03:51,840\n但缺乏迭代或推导机制\n\n95\n00:03:51,840 --> 00:03:54,380\n这也是思维链有效的原因之一\n\n96\n00:03:54,380 --> 00:03:57,640\n现在模型无需一次性解决全部问题\n\n97\n00:03:57,640 --> 00:03:59,900\n可写出中间思考过程\n\n98\n00:03:59,900 --> 00:04:00,660\n回读内容\n\n99\n00:04:00,660 --> 00:04:01,900\n更新内部状态\n\n100\n00:04:01,900 --> 00:04:02,840\n撰写下一步思考\n\n101\n00:04:02,840 --> 00:04:03,880\n再读一遍\n\n102\n00:04:03,880 --> 00:04:06,500\n并不断重复直到得到答案\n\n103\n00:04:06,500 --> 00:04:10,280\n推理模型中的思维链本质上是在创建迭代过程\n\n104\n00:04:10,280 --> 00:04:11,880\n通过生成额外的标记\n\n105\n00:04:11,880 --> 00:04:15,700\n但这里开始显得不够优雅\n\n106\n00:04:15,700 --> 00:04:18,440\n因为每次模型生成推理标记\n\n107\n00:04:18,440 --> 00:04:20,760\n该标记必须解码为文本\n\n108\n00:04:20,760 --> 00:04:22,180\n附加到上下文\n\n109\n00:04:22,180 --> 00:04:25,500\n然后在下一次迭代中重新嵌入到隐藏状态\n\n110\n00:04:25,500 --> 00:04:28,080\n这意味着模型必须反复执行此操作\n\n111\n00:04:28,080 --> 00:04:30,720\n在语言自身中进行解压和压缩循环\n\n112\n00:04:30,720 --> 00:04:32,800\n只为优化其潜在状态\n\n113\n00:04:32,800 --> 00:04:33,660\n除此之外\n\n114\n00:04:33,660 --> 00:04:36,520\n这些标记是从模型输出分布中采样的\n\n115\n00:04:36,520 --> 00:04:40,000\n因此模型并未直接修改推理分布\n\n116\n00:04:40,000 --> 00:04:42,620\n而是输出采样的文本轨迹\n\n117\n00:04:42,620 --> 00:04:45,280\n随后基于该简单轨迹进行条件处理\n\n118\n00:04:45,280 --> 00:04:49,140\n这意味着推理过程通过离散标记生成进行中介\n\n119\n00:04:49,140 --> 00:04:52,300\n而非直接体现在计算本身中\n\n120\n00:04:52,300 --> 00:04:55,540\n如果你要设计递归架构\n\n121\n00:04:55,540 --> 00:04:57,640\n理论上应该更简洁\n\n122\n00:04:57,640 --> 00:05:01,040\n因为可以让模型直接更新隐藏状态\n\n123\n00:05:01,040 --> 00:05:04,360\n这在时间和能耗上更高效\n\n124\n00:05:04,360 --> 00:05:08,520\n因为模型重复利用内部计算并直接作用于表示\n\n125\n00:05:08,520 --> 00:05:11,240\n而非不断将其外部化为标记\n\n126\n00:05:11,240 --> 00:05:15,280\n这引出了一个近期备受关注的新架构理念\n\n127\n00:05:15,280 --> 00:05:18,060\n2026年四月提出的循环变换器\n\n128\n00:05:18,060 --> 00:05:19,700\n核心思想非常简单\n\n129\n00:05:19,700 --> 00:05:23,180\n不是使用单次的长栈式独特变换层\n\n130\n00:05:23,180 --> 00:05:24,620\n这是典型设置\n\n131\n00:05:24,620 --> 00:05:29,200\n仅取几层组成小模块并重复运行\n\n132\n00:05:29,200 --> 00:05:32,900\n前一次循环的输出隐藏状态成为同一模块的输入\n\n133\n00:05:32,900 --> 00:05:36,380\n模型可在多次内部步骤中优化表示\n\n134\n00:05:36,380 --> 00:05:40,480\n而非将所有内容强制压缩为单次变换\n\n135\n00:05:40,480 --> 00:05:43,380\n《Think and Generalize》发表于2026年四月\n\n136\n00:05:43,380 --> 00:05:45,120\n他们采用了这一架构\n\n137\n00:05:45,120 --> 00:05:46,320\n通过迭代\n\n138\n00:05:46,320 --> 00:05:48,960\n发现模型在多跳推理上表现更好\n\n139\n00:05:48,960 --> 00:05:51,220\n不仅限于训练时的跳数\n\n140\n00:05:51,220 --> 00:05:52,280\n甚至超过训练深度\n\n141\n00:05:52,280 --> 00:05:55,400\n当推理时增加更多循环迭代\n\n142\n00:05:55,400 --> 00:06:00,680\n可见其三阶段振荡训练过程中多跳推理能力的涌现\n\n143\n00:06:00,680 --> 00:06:01,020\n第二阶段\n\n144\n00:06:01,020 --> 00:06:02,320\n观察训练曲线\n\n145\n00:06:02,320 --> 00:06:05,220\n初期模型主要在记忆训练数据\n\n146\n00:06:05,220 --> 00:06:08,460\n随着训练集准确率提升并饱和\n\n147\n00:06:08,460 --> 00:06:10,140\n进入第二阶段\n\n148\n00:06:10,140 --> 00:06:12,340\n开始在分布上泛化\n\n149\n00:06:12,340 --> 00:06:14,620\n当分布测试达到上限\n\n150\n00:06:14,620 --> 00:06:19,980\n通常表明模型能处理遵循相同训练结构的复合问题\n\n151\n00:06:19,980 --> 00:06:22,120\n即使问题本身是全新的\n\n152\n00:06:22,120 --> 00:06:24,320\n随后第三阶段出现\n\n153\n00:06:24,320 --> 00:06:26,480\n这是一个系统化阶段\n\n154\n00:06:26,480 --> 00:06:32,300\n模型能够以训练期间从未组合过的知识片段进行创新组合\n\n155\n00:06:32,300 --> 00:06:35,240\n这意味着它们可以进行分布外泛化\n\n156\n00:06:35,240 --> 00:06:40,360\n最终我学会了一种可复用的推理答案组合方法\n\n157\n00:06:40,360 --> 00:06:42,840\n而基础Transformer模型难以做到这一点\n\n158\n00:06:42,840 --> 00:06:47,540\n因为它能以非传统方式组合事实并难以进行外推\n\n159\n00:06:47,540 --> 00:06:49,980\n当推理时增加循环次数\n\n160\n00:06:49,980 --> 00:06:52,740\n超过训练时使用的循环次数\n\n161\n00:06:52,740 --> 00:06:56,240\n它能够实现比训练时更多的跳跃\n\n162\n00:06:56,240 --> 00:06:59,600\n在此设置中，递归次数成为计算调节器\n\n163\n00:06:59,600 --> 00:07:02,980\n你可以让模型更长时间思考并期待更好结果\n\n164\n00:07:02,980 --> 00:07:03,720\n但当然\n\n165\n00:07:03,720 --> 00:07:06,380\n一旦将递归直接引入架构\n\n166\n00:07:06,380 --> 00:07:09,460\n也会带来新的稳定性问题\n\n167\n00:07:09,460 --> 00:07:12,520\n因为现在不再应用不同层的序列处理\n\n168\n00:07:12,520 --> 00:07:16,920\n而是对隐藏状态重复应用相同变换\n\n169\n00:07:16,920 --> 00:07:20,500\n同时需要决定重复块的次数\n\n170\n00:07:20,500 --> 00:07:23,200\n同时确保信息不会变得混乱\n\n171\n00:07:23,200 --> 00:07:24,640\n因为一旦你开始循环\n\n172\n00:07:24,640 --> 00:07:26,500\n你不再只是在设计一个网络\n\n173\n00:07:26,500 --> 00:07:28,360\n你是在设计一种思考过程\n\n174\n00:07:28,360 --> 00:07:31,440\n而每一次递归都是同一更新规则的再次应用\n\n175\n00:07:31,440 --> 00:07:33,280\n因此微小的偏差会被放大\n\n176\n00:07:33,280 --> 00:07:34,400\n错误会累积\n\n177\n00:07:34,400 --> 00:07:37,560\n模型很容易偏离稳定轨迹\n\n178\n00:07:37,560 --> 00:07:40,400\n模型可能会直接拒绝收敛并爆炸\n\n179\n00:07:40,400 --> 00:07:43,080\n这就是下篇论文要解决的问题\n\n180\n00:07:43,080 --> 00:07:45,420\n不再将循环简单视为重复的层\n\n181\n00:07:45,420 --> 00:07:49,180\n他们明确将其建模为残差流上的动态系统\n\n182\n00:07:49,180 --> 00:07:52,260\n并分析为何朴素循环变压器会变得不稳定\n\n183\n00:07:52,260 --> 00:07:54,840\n但为何它与残差流紧密相关\n\n184\n00:07:54,840 --> 00:07:58,480\n因为模型的隐藏状态在每次出现时都会向前传播并更新\n\n185\n00:07:58,480 --> 00:08:00,280\n而非从头重新计算\n\n186\n00:08:00,280 --> 00:08:01,040\n在每次循环中\n\n187\n00:08:01,040 --> 00:08:02,620\n重用之前的隐藏状态\n\n188\n00:08:02,620 --> 00:08:04,880\n并与注入输入混合\n\n189\n00:08:04,880 --> 00:08:08,460\n应用Transformer操作并生成下一个隐藏状态\n\n190\n00:08:08,460 --> 00:08:11,780\n因此残差流本质上是模型演化的潜在状态\n\n191\n00:08:11,780 --> 00:08:15,380\n信息在递归过程中累积的主要通道\n\n192\n00:08:15,380 --> 00:08:16,960\n如果动态系统不稳定\n\n193\n00:08:16,960 --> 00:08:19,580\n则隐藏状态的范数会在递归中增长\n\n194\n00:08:19,580 --> 00:08:20,560\n这会导致损失增加\n\n195\n00:08:20,560 --> 00:08:21,640\n出现脉冲和发散现象\n\n196\n00:08:21,640 --> 00:08:24,360\n他们只需要约束并归一化\n\n197\n00:08:24,360 --> 00:08:27,920\n确保每次更新不会因失控积累而崩溃\n\n198\n00:08:27,920 --> 00:08:31,100\n这解决了循环变压器的关键问题之一\n\n199\n00:08:31,100 --> 00:08:33,200\n但即使无法稳定循环\n\n200\n00:08:33,200 --> 00:08:36,059\n如何确定模型真正在推理\n\n201\n00:08:36,059 --> 00:08:39,080\n仅仅更好的多跳性能本身其实还不够\n\n202\n00:08:39,080 --> 00:08:41,559\n我们只是推测这可能会有效\n\n203\n00:08:41,559 --> 00:08:42,679\n另一篇论文\n\n204\n00:08:42,679 --> 00:08:45,020\n同样于2026年4月发表\n\n205\n00:08:45,020 --> 00:08:49,560\n《循环推理模型的机制分析》将这一现象完美呈现\n\n206\n00:08:49,560 --> 00:08:54,540\n他们的方法是追踪递归过程中的潜在状态并观察其演变\n\n207\n00:08:54,540 --> 00:08:57,400\n但由于这些隐藏状态维度极高\n\n208\n00:08:57,400 --> 00:08:59,180\n无法直接可视化\n\n209\n00:08:59,180 --> 00:09:02,520\n因此使用PCA等工具\n\n210\n00:09:02,520 --> 00:09:07,940\n这是一种将高维激活空间压缩到主要方向的方法\n\n211\n00:09:07,940 --> 00:09:09,780\n解释大部分变化\n\n212\n00:09:09,780 --> 00:09:10,820\n简单来说\n\n213\n00:09:10,820 --> 00:09:14,900\n它能让模型内部状态投影到二维或三维\n\n214\n00:09:14,900 --> 00:09:15,300\nD地图\n\n215\n00:09:15,300 --> 00:09:18,640\n因此可以看到应用是否随机漂移\n\n216\n00:09:18,640 --> 00:09:20,900\n崩溃或遵循稳定轨迹\n\n217\n00:09:20,900 --> 00:09:24,980\n他们发现这些循环模型趋向稳定轨迹\n\n218\n00:09:24,980 --> 00:09:25,940\n在潜在空间中\n\n219\n00:09:25,940 --> 00:09:26,860\n在某些情况下\n\n220\n00:09:26,860 --> 00:09:30,440\n看起来像固定点，表示逐渐稳定\n\n221\n00:09:30,440 --> 00:09:31,320\n在其他情况下\n\n222\n00:09:31,320 --> 00:09:33,020\n呈现周期性轨迹\n\n223\n00:09:33,020 --> 00:09:37,380\n隐藏状态在重复块中重复访问一致状态\n\n224\n00:09:37,380 --> 00:09:43,000\n内部过程不会不可预测地改变表示或快速坍缩\n\n225\n00:09:43,000 --> 00:09:46,080\n但他们进一步分析注意力\n\n226\n00:09:46,080 --> 00:09:47,620\n行为随递归的变化\n\n227\n00:09:47,620 --> 00:09:51,640\n观察到当隐藏状态接近固定点或循环时\n\n228\n00:09:51,640 --> 00:09:54,460\n注意力头行为也趋于稳定\n\n229\n00:09:54,460 --> 00:09:56,960\n不仅仅是激活值趋于平静\n\n230\n00:09:56,960 --> 00:10:00,920\n块执行的计算也变得更一致\n\n231\n00:10:00,920 --> 00:10:01,760\n更令人着迷的是\n\n232\n00:10:01,760 --> 00:10:02,280\n是\n\n233\n00:10:02,280 --> 00:10:04,880\n循环块能学习推理阶段\n\n234\n00:10:04,880 --> 00:10:08,120\n与Transformer的阶段相似\n\n235\n00:10:08,120 --> 00:10:11,940\n但这些阶段通过循环组织\n\n236\n00:10:11,940 --> 00:10:13,340\n早期递归\n\n237\n00:10:13,340 --> 00:10:16,340\n中期递归和后期递归可承担不同角色\n\n238\n00:10:16,340 --> 00:10:18,200\n尽管权重共享\n\n239\n00:10:18,200 --> 00:10:21,760\n早期递归构建问题粗略表示\n\n240\n00:10:21,760 --> 00:10:25,080\n模型收集并组织相关信息\n\n241\n00:10:25,080 --> 00:10:27,820\n更新更大且更具探索性\n\n242\n00:10:27,820 --> 00:10:29,900\n但进入中期迭代时\n\n243\n00:10:29,900 --> 00:10:33,880\n模型开始整合信息并传递关系\n\n244\n00:10:33,880 --> 00:10:37,820\n此时更新更结构化而非随意形成\n\n245\n00:10:37,820 --> 00:10:39,320\n在后期迭代中\n\n246\n00:10:39,320 --> 00:10:40,960\n更新帮助模型\n\n247\n00:10:40,960 --> 00:10:44,980\n主要稳定表示并收敛至最终答案\n\n248\n00:10:44,980 --> 00:10:46,440\n尽管块是共享的\n\n249\n00:10:46,440 --> 00:10:50,140\n循环并非重复相同计算\n\n250\n00:10:50,140 --> 00:10:53,260\n每次输入到块的内容不同\n\n251\n00:10:53,260 --> 00:10:56,460\n这迫使同一功能在每一步表现出不同的行为\n\n252\n00:10:56,460 --> 00:11:00,260\n这自然形成了从课程理解到精细解决方案的递进过程\n\n253\n00:11:00,260 --> 00:11:01,520\n这真是太美妙了\n\n254\n00:11:01,520 --> 00:11:04,190\n但仍有更多优化空间\n\n255\n00:11:04,190 --> 00:11:06,780\n因为即使循环能提供内部推理\n\n256\n00:11:06,780 --> 00:11:10,360\n你仍对每个标记应用相同数量的递归\n\n257\n00:11:10,360 --> 00:11:13,440\n无论标记是简单还是极其复杂\n\n258\n00:11:13,440 --> 00:11:15,740\n仍需经过相同次数的循环\n\n259\n00:11:15,740 --> 00:11:18,520\n这引入了新的低效性\n\n260\n00:11:18,520 --> 00:11:22,400\n因为现在即使不需要也要均匀分配计算资源\n\n261\n00:11:22,400 --> 00:11:28,760\n这种确切限制正是这篇七月发表的混合递归论文试图解决的问题\n\n262\n00:11:28,760 --> 00:11:30,560\n2025年尝试解决\n\n263\n00:11:30,560 --> 00:11:33,260\n不再强制每个标记通过相同数量的\n\n264\n00:11:33,260 --> 00:11:37,920\n引入一个路由器决定每个标记实际需要的递归次数\n\n265\n00:11:37,920 --> 00:11:41,380\n在论文中，这两种方法被整合到MOR模型中\n\n266\n00:11:41,380 --> 00:11:42,200\n在其中一个版本中\n\n267\n00:11:42,200 --> 00:11:45,460\n路由器将每个标记分配到递归深度桶\n\n268\n00:11:45,460 --> 00:11:46,960\n在循环开始前\n\n269\n00:11:46,960 --> 00:11:49,680\n预测该标记应经过的步骤数量\n\n270\n00:11:49,680 --> 00:11:53,040\n这种方法效率很高，因为计算路径从一开始就固定\n\n271\n00:11:53,040 --> 00:11:56,180\n但严重依赖初始预测的准确性\n\n272\n00:11:56,180 --> 00:11:58,960\n比如如果模型早期误判难度\n\n273\n00:11:58,960 --> 00:12:00,300\n后期无法调整\n\n274\n00:12:00,300 --> 00:12:01,460\n在另一个版本中\n\n275\n00:12:01,460 --> 00:12:03,340\n决策是逐步进行的\n\n276\n00:12:03,340 --> 00:12:04,460\n在每次迭代时\n\n277\n00:12:04,460 --> 00:12:06,840\n模型可以选择继续或退出\n\n278\n00:12:06,840 --> 00:12:09,980\n这更具灵活性，能随着表示演进而适应\n\n279\n00:12:09,980 --> 00:12:12,460\n通常能更高效分配计算资源\n\n280\n00:12:12,460 --> 00:12:12,780\n然而\n\n281\n00:12:12,780 --> 00:12:16,240\n实现稍复杂且训练时更难稳定\n\n282\n00:12:16,240 --> 00:12:20,800\n因为决策过程重复进行而非一次性完成\n\n283\n00:12:20,800 --> 00:12:22,040\n但逐步版本\n\n284\n00:12:22,040 --> 00:12:23,920\n他们称为专家选择路由\n\n285\n00:12:23,920 --> 00:12:27,280\n最终效果并不比前期分配版本更好\n\n286\n00:12:27,280 --> 00:12:28,960\n他们称为标记选择路由\n\n287\n00:12:28,960 --> 00:12:31,000\n在相同的三递归设置下\n\n288\n00:12:31,000 --> 00:12:35,400\n专家选择路由达到平均42.6%的少样本准确率\n\n289\n00:12:35,400 --> 00:12:37,800\n而标记选择路由降至40%\n\n290\n00:12:37,800 --> 00:12:40,320\n尽管标记选择在理论上更清洁\n\n291\n00:12:40,320 --> 00:12:44,260\n但实际每个钩子从一开始就承诺完整计算路径\n\n292\n00:12:44,260 --> 00:12:45,680\n实际上并无太大优势\n\n293\n00:12:45,680 --> 00:12:48,220\n这表明在迭代开始前决定标记所需思考量\n\n294\n00:12:48,220 --> 00:12:51,540\n实在太过困难\n\n295\n00:12:51,540 --> 00:12:51,980\n但总之\n\n296\n00:12:51,980 --> 00:12:54,700\n这些就是额外效率优化的来源\n\n297\n00:12:54,700 --> 00:12:55,420\n然而\n\n298\n00:12:55,420 --> 00:12:57,220\n一旦使递归自适应\n\n299\n00:12:57,220 --> 00:12:59,260\n另一个瓶颈立即显现\n\n300\n00:12:59,260 --> 00:13:01,860\n那就是标准Transformer中的KV缓存\n\n301\n00:13:01,860 --> 00:13:05,080\n每一层都存储每个token的键和值张量\n\n302\n00:13:05,080 --> 00:13:07,280\n这会迅速消耗内存和带宽\n\n303\n00:13:07,280 --> 00:13:09,220\n尤其是在长上下文解码时\n\n304\n00:13:09,220 --> 00:13:12,160\n递归模型在简单设置下会更糟\n\n305\n00:13:12,160 --> 00:13:13,960\n尽管参数是共享的\n\n306\n00:13:13,960 --> 00:13:17,500\n你仍需为每个递归深度维护独立的kv缓存\n\n307\n00:13:17,500 --> 00:13:20,280\n因此实际上并未显著减少内存流量\n\n308\n00:13:20,280 --> 00:13:23,580\n但Moir通过改变kv缓存机制解决了这个问题\n\n309\n00:13:23,580 --> 00:13:25,320\n以匹配自适应递归\n\n310\n00:13:25,320 --> 00:13:27,980\n他们的第一策略是递归感知缓存\n\n311\n00:13:27,980 --> 00:13:31,140\n仅存储仍处于活跃状态的token的kv对\n\n312\n00:13:31,140 --> 00:13:32,640\n在给定的递归步骤中\n\n313\n00:13:32,640 --> 00:13:34,280\n由于token可能提前退出\n\n314\n00:13:34,280 --> 00:13:35,360\n更深的递归\n\n315\n00:13:35,360 --> 00:13:36,780\n处理更少的token\n\n316\n00:13:36,780 --> 00:13:41,160\n这意味着内存使用和注意力计算随深度增加而缩小\n\n317\n00:13:41,160 --> 00:13:42,520\n这使模型更高效\n\n318\n00:13:42,520 --> 00:13:44,220\n不仅在参数层面\n\n319\n00:13:44,220 --> 00:13:46,420\n也在实际运行行为上\n\n320\n00:13:46,420 --> 00:13:50,760\n因为避免了为不再需要进一步处理的token浪费内存带宽\n\n321\n00:13:50,760 --> 00:13:53,380\n第二策略是递归kv共享\n\n322\n00:13:53,380 --> 00:13:55,820\n因此不再在每次递归时存储kv对\n\n323\n00:13:55,820 --> 00:14:00,840\n模型在首次递归时缓存并重复使用后续步骤\n\n324\n00:14:00,840 --> 00:14:03,240\n这大幅降低内存占用\n\n325\n00:14:03,240 --> 00:14:06,450\n因为你不再跨递归深度复制kv状态\n\n326\n00:14:06,450 --> 00:14:06,970\n然而\n\n327\n00:14:06,970 --> 00:14:11,850\n这存在权衡因为后续递归会关注稍旧的表示\n\n328\n00:14:11,850 --> 00:14:15,020\n相比递归感知缓存可能影响性能\n\n329\n00:14:15,020 --> 00:14:19,960\n递归感知缓存更准确因为它每步保持表示新鲜\n\n330\n00:14:19,960 --> 00:14:21,780\n但内存消耗更大\n\n331\n00:14:21,780 --> 00:14:22,880\n另一方面\n\n332\n00:14:22,880 --> 00:14:25,240\n递归共享更节省内存\n\n333\n00:14:25,240 --> 00:14:26,620\n但略微降低质量\n\n334\n00:14:26,620 --> 00:14:28,120\n所以这并非问题\n\n335\n00:14:28,120 --> 00:14:30,880\n论文表明这些权衡是可控的\n\n336\n00:14:30,880 --> 00:14:35,060\n两种方法仍优于递归模型和标准Transformer\n\n337\n00:14:35,060 --> 00:14:37,300\n结合自适应路由时\n\n338\n00:14:37,300 --> 00:14:41,900\n你知道现在是什么时候了 该解决房间里的大象了\n\n339\n00:14:41,900 --> 00:14:45,060\n在这些新技巧发布后\n\n340\n00:14:45,060 --> 00:14:48,580\n针对其缺陷的解决方案也被提出\n\n341\n00:14:48,580 --> 00:14:52,880\n循环Transformer在当前语言模型生态中的竞争力如何\n\n342\n00:14:52,880 --> 00:14:57,960\n尽管循环Transformer的主要反对仍在于其表达能力\n\n343\n00:14:57,960 --> 00:14:59,420\n更深或更宽的模型\n\n344\n00:14:59,420 --> 00:15:04,160\n拥有独特层的模型比共享块具有更强的表达能力\n\n345\n00:15:04,160 --> 00:15:09,180\n从纯优化角度看循环是同一问题的受限版本\n\n346\n00:15:09,180 --> 00:15:10,780\n如果你不受内存限制\n\n347\n00:15:10,780 --> 00:15:14,460\n标准Transformer简单增加参数就能轻松胜出\n\n348\n00:15:14,460 --> 00:15:17,400\n并可避免复杂的kv缓存问题\n\n349\n00:15:17,400 --> 00:15:20,160\n相比标准链式思维推理方法\n\n350\n00:15:20,160 --> 00:15:20,740\n实证结果表明\n\n351\n00:15:20,740 --> 00:15:24,220\n不受限制的Transformer模型往往难以达到更低的损失值并不令人意外\n\n352\n00:15:24,220 --> 00:15:26,560\n在参数规模自由扩展的基础上\n\n353\n00:15:26,560 --> 00:15:31,600\n扩展定律历史上更倾向于增加参数数量而非重复利用计算\n\n354\n00:15:31,600 --> 00:15:33,900\n第二个问题是关于深度本身\n\n355\n00:15:33,900 --> 00:15:38,240\n尽管循环Transformer可以通过增加递归次数模拟更深层的计算\n\n356\n00:15:38,240 --> 00:15:41,720\n这与拥有真正更深的架构并不相同\n\n357\n00:15:41,720 --> 00:15:45,580\n堆叠的独特层可以在每一步学习不同的变换\n\n358\n00:15:45,580 --> 00:15:48,740\n而循环模型必须重复使用相同的函数\n\n359\n00:15:48,740 --> 00:15:52,820\n并希望通过演变的隐藏状态诱导不同行为\n\n360\n00:15:52,820 --> 00:15:56,800\n机制分析论文表明这在实践中可能出现\n\n361\n00:15:56,800 --> 00:16:01,380\n但这仍比显式提供不同层的归纳偏差更弱\n\n362\n00:16:01,380 --> 00:16:04,240\n因此可以说如果深度是瓶颈\n\n363\n00:16:04,240 --> 00:16:08,580\n直接扩展深度可能比通过递归模拟更有效\n\n364\n00:16:08,580 --> 00:16:10,780\n假设计算和内存允许\n\n365\n00:16:10,780 --> 00:16:15,160\n接下来是循环Transformer是否在推理上更具优势的问题\n\n366\n00:16:15,160 --> 00:16:17,660\n但目前我们缺乏足够证据\n\n367\n00:16:17,660 --> 00:16:21,940\n然而多跳基准测试和深度外推结果很有趣\n\n368\n00:16:21,940 --> 00:16:25,000\n但仍在相对受控的环境中\n\n369\n00:16:25,000 --> 00:16:29,560\n因此这些收益是否完全转化为大规模实际任务尚不明确\n\n370\n00:16:29,560 --> 00:16:33,960\n标准Transformer已通过大规模预训练和涌现行为获益\n\n371\n00:16:33,960 --> 00:16:34,780\n除此之外\n\n372\n00:16:34,780 --> 00:16:37,600\n思维链具有明显优势\n\n373\n00:16:37,600 --> 00:16:38,240\n即\n\n374\n00:16:38,240 --> 00:16:42,040\n模型通过显式写出标记进行推理\n\n375\n00:16:42,040 --> 00:16:46,160\n这意味着可以基于这些痕迹进行监督学习\n\n376\n00:16:46,160 --> 00:16:47,000\n筛选这些痕迹\n\n377\n00:16:47,000 --> 00:16:47,920\n基于这些痕迹进行强化\n\n378\n00:16:47,920 --> 00:16:49,840\n并直接训练模仿这些痕迹\n\n379\n00:16:49,840 --> 00:16:52,480\n即使推理过程效率低下\n\n380\n00:16:52,480 --> 00:16:55,040\n至少训练信号非常明确\n\n381\n00:16:55,040 --> 00:16:59,780\n因为模型能明确看到预期的中间步骤\n\n382\n00:16:59,780 --> 00:17:01,440\n甚至可以对其进行监督\n\n383\n00:17:01,440 --> 00:17:05,060\n但循环Transformer的隐藏状态递归无法享受这种优势\n\n384\n00:17:05,060 --> 00:17:08,400\n中间计算隐含在隐藏状态中\n\n385\n00:17:08,400 --> 00:17:12,020\n没有自然文本痕迹指导模型第一步\n\n386\n00:17:12,020 --> 00:17:12,319\n第二步\n\n387\n00:17:12,319 --> 00:17:13,099\n第三步应如何\n\n388\n00:17:13,099 --> 00:17:15,720\n模型必须自行发现这种结构\n\n389\n00:17:15,720 --> 00:17:17,560\n完全通过最终目标\n\n390\n00:17:17,560 --> 00:17:20,000\n因此递归可能架构更简洁\n\n391\n00:17:20,000 --> 00:17:23,280\n但难以监督因为我们无法引导\n\n392\n00:17:23,280 --> 00:17:25,000\n我唯一看到的潜在优势\n\n393\n00:17:25,000 --> 00:17:28,860\n循环的优势在于能以计算换取有效深度\n\n394\n00:17:28,860 --> 00:17:30,640\n而不增加参数量\n\n395\n00:17:30,640 --> 00:17:34,000\n这对合成数据生成场景可能有用\n\n396\n00:17:34,000 --> 00:17:36,000\n蒸馏或边缘部署\n\n397\n00:17:36,000 --> 00:17:39,180\n例如在移动设备等无法承载大模型的场景\n\n398\n00:17:39,180 --> 00:17:41,160\n但仍需精细优化\n\n399\n00:17:41,160 --> 00:17:45,320\n并且在思维链效率或智能不足时\n\n400\n00:17:45,320 --> 00:17:48,620\n循环Transformer可能超越同参数量级模型\n\n401\n00:17:48,620 --> 00:17:50,980\n因为它们能高效复用计算\n\n402\n00:17:50,980 --> 00:17:55,120\n但在大规模推理场景中，延迟和吞吐量比参数数量更重要\n\n403\n00:17:55,120 --> 00:17:57,940\n重复应用相同模块反而可能影响性能\n\n404\n00:17:57,940 --> 00:18:00,330\n相比优化良好的前馈堆栈\n\n405\n00:18:00,330 --> 00:18:03,090\n所以未来或许在微型模型中\n\n406\n00:18:03,090 --> 00:18:04,720\n可以应用Transformer架构\n\n407\n00:18:04,720 --> 00:18:05,540\n但你怎么看呢\n\n408\n00:18:05,540 --> 00:18:07,760\n你觉得他们探索的研究方向如何\n\n409\n00:18:07,760 --> 00:18:08,880\n在评论区告诉我吧\n\n410\n00:18:08,880 --> 00:18:11,980\n如果你想深入了解模型工作原理\n\n411\n00:18:11,980 --> 00:18:13,540\n而不被数学公式淹没\n\n412\n00:18:13,540 --> 00:18:16,740\n你应该看看我的最新项目Intuitive AI学院\n\n413\n00:18:16,740 --> 00:18:20,420\n这里包含从基础构建的现代L模型直观解释\n\n414\n00:18:20,420 --> 00:18:22,880\n包括蒸馏等技术细节\n\n415\n00:18:22,880 --> 00:18:24,480\n正如我在本视频中提到的\n\n416\n00:18:24,480 --> 00:18:26,120\n我们从基础开始讲解一切\n\n417\n00:18:26,120 --> 00:18:27,580\n比如Transformer架构\n\n418\n00:18:27,580 --> 00:18:29,860\n一直深入到LaRA等高级主题\n\n419\n00:18:29,860 --> 00:18:31,740\n专家混合与强化学习\n\n420\n00:18:31,740 --> 00:18:34,980\n我们新增了优化器章节\n\n421\n00:18:34,980 --> 00:18:38,460\n将内容从经典方法带到前沿技术\n\n422\n00:18:38,460 --> 00:18:39,640\n无论你是学生\n\n423\n00:18:39,640 --> 00:18:40,720\n软件开发者\n\n424\n00:18:40,720 --> 00:18:43,260\n还是想转型进入AI领域的学习者\n\n425\n00:18:43,260 --> 00:18:47,100\nAI学院为你提供建立真实技术直觉的平台\n\n426\n00:18:47,100 --> 00:18:50,960\n使用代码LOCKIN可享年费会员三五折优惠\n\n427\n00:18:50,960 --> 00:18:53,840\n感谢大家观看，特别感谢Spam Match\n\n428\n00:18:53,840 --> 00:18:56,000\nCrystal Do Degan\n\n429\n00:18:56,000 --> 00:18:56,500\nRobert\n\n430\n00:18:56,500 --> 00:18:57,460\nZayasa\n\n431\n00:18:57,460 --> 00:18:58,140\nMarcelo\n\n432\n00:18:58,140 --> 00:18:58,860\nFerraria\n\n433\n00:18:58,860 --> 00:19:00,620\nPoof和New DX\n\n434\n00:19:00,620 --> 00:19:01,380\n研究团队\n\n435\n00:19:01,380 --> 00:19:02,310\nAlex\n\n436\n00:19:02,310 --> 00:19:03,450\nIt Was Maker\n\n437\n00:19:03,450 --> 00:19:05,810\n以及通过Patreon或YouTube支持我的许多人\n\n438\n00:19:05,810 --> 00:19:06,670\n在Twitter关注我\n\n439\n00:19:06,670 --> 00:19:07,190\n如果还没关注的话\n\n440\n00:19:07,190 --> 00:19:09,060\n我们下期再见\n\n"}]}, "webpage_url": "https://www.bilibili.com/video/BV1x5Tk6EEMN/?buvid=Z8427A84BDF99B244B98A866C02B9CB42F9C&from_spmid=search.search-result.0.0&is_story_h5=false&mid=pcYGa8O5%2F2lqRf%2BRIKl0oQ%3D%3D&p=1&plat_id=116&share_from=ugc&share_medium=iphone&share_plat=ios&share_session_id=8ABD7F75-CC50-4246-B7FB-300CB9697712&share_source=COPY&share_tag=s_i&spmid=united.player-video-detail.0.0&timestamp=1783006285&unique_k=D2nUhxC&up_id=435076601", "webpage_url_basename": "BV1x5Tk6EEMN", "webpage_url_domain": "bilibili.com", "extractor": "BiliBili", "extractor_key": "BiliBili", "thumbnails": [{"url": "http://i0.hdslb.com/bfs/archive/433493916706b44e990d840ae01dfaa86aab93bc.png", "id": "0"}], "display_id": "BV1x5Tk6EEMN_p1", "fulltitle": "放弃思维链？大模型新架构Loop Transformer硬核解析 | bycloud", "duration_string": "19:09", "upload_date": "20260702", "epoch": 1783006537, "format": "1080P 高码率+30280 - audio only", "format_id": "30112+30280", "ext": "mp4", "protocol": "https+https", "filesize_approx": 174073737, "tbr": 1211.912, "width": 1920, "height": 1080, "resolution": "1920x1080", "fps": 29.962, "dynamic_range": "SDR", "vcodec": "avc1.640033", "vbr": 1131.809, "aspect_ratio": 1.78, "acodec": "mp4a.40.2", "abr": 80.103, "_type": "video", "_version": {"version": "2026.05.05.233942", "release_git_head": "c8695f52a91f0d2aabbba7b7200c1099bfa9a3e5", "repository": "yt-dlp/yt-dlp-nightly-builds"}}